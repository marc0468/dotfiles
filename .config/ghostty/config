# ============display============
# theme = Solarized Osaka Night
theme = Ayu Mirage
background-opacity = 0.85
background-blur-radius = 15
unfocused-split-opacity = 0.6
cursor-style = block
macos-titlebar-style = transparent
macos-option-as-alt = true

# ============font============
font-family = UDEV Gothic 35NF
font-feature = -calt
font-feature = -liga
font-feature = -dlig

# ============clipbord============
copy-on-select = clipboard
clipboard-read = allow
clipboard-write = allow

shell-integration = zsh
# shell-integration-features = ssh-terminfo,ssh-env

# ============keybind============
keybind = super+shift+-=new_split:down
keybind = super+shift+¥=new_split:right

keybind = super+left=goto_split:left
keybind = super+right=goto_split:right
keybind = super+up=goto_split:top
keybind = super+down=goto_split:bottom

keybind = super+shift+left=resize_split:left,20
keybind = super+shift+right=resize_split:right,20
keybind = super+shift+up=resize_split:up,20
keybind = super+shift+down=resize_split:down,20

keybind = super+w=close_surface
